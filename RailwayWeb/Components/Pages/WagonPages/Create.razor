@page "/wagons/create"
@using Microsoft.EntityFrameworkCore
@using RailwayWeb.Data
@inject IDbContextFactory<RailwayWebContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create</PageTitle>

<h1>Create New Wagon</h1>

<h4>Wagon</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <EditForm Method="Post" Model="Wagon" OnValidSubmit="AddWagon" FormName="create" Enhance>
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" />

            <div class="mb-3">
                <label for="payload" class="form-label">Payload:</label> 
                <InputNumber id="payload" @bind-Value="Wagon.Payload" class="form-control" /> 
                <ValidationMessage For="() => Wagon.Payload" class="text-danger" /> 
            </div>        

            <div class="mb-3">
                <label for="volume" class="form-label">Volume:</label> 
                <InputNumber id="volume" @bind-Value="Wagon.Volume" class="form-control" /> 
                <ValidationMessage For="() => Wagon.Volume" class="text-danger" /> 
            </div>  

             <div class="mb-3">
                <label for="dimensions" class="form-label">Dimensions:</label> 
                <InputText id="dimensions" @bind-Value="Wagon.Dimensions" class="form-control" /> 
                <ValidationMessage For="() => Wagon.Dimensions" class="text-danger" /> 
            </div> 

             <div class="mb-3">
                <label for="weight" class="form-label">Weight:</label> 
                <InputNumber id="weight" @bind-Value="Wagon.Weight" class="form-control" /> 
                <ValidationMessage For="() => Wagon.Weight" class="text-danger" /> 
            </div> 

             <div class="mb-3">
                <label for="tare" class="form-label">Tare:</label> 
                <InputNumber id="tare" @bind-Value="Wagon.Tare" class="form-control" /> 
                <ValidationMessage For="() => Wagon.Tare" class="text-danger" /> 
            </div> 

            <button type="submit" class="btn btn-primary">Create</button>
        </EditForm>
    </div>
</div>

<div>
    <a href="/wagons">Back to List</a>
</div>

@code {
    [SupplyParameterFromForm]
    public Wagon Wagon { get; set; } = new();

    public async Task AddWagon()
    {
        using var context = DbFactory.CreateDbContext();
        context.Wagon.Add(Wagon);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/wagons");
    }
}
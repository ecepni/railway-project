@page "/linesegments/delete"
@using Microsoft.EntityFrameworkCore
@using RailwayWeb.Data
@inject IDbContextFactory<RailwayWebContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Segment</PageTitle>

<h1>Delete Segment</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Line Segment</h4>
    <hr />
    @if (lineSegment is null)
    {
            <p><em>Loading...</em></p>
    }
    else
    {
            <dl class="row">
                <dt class="col-sm-2">ID</dt>
                <dd class="col-sm-10">@lineSegment.SegmentID</dd>

                <dt class="col-sm-2">Location</dt>
                <dd class="col-sm-10">@lineSegment.Location</dd>

                <dt class="col-sm-2">Line ID</dt>
                <dd class="col-sm-10">@lineSegment.LineID</dd>
            </dl>

            <EditForm Method="Post" Model="lineSegment" OnValidSubmit="DeleteSegment" FormName="delete" Enhance>
                 <input type="hidden" name="lineSegment.SegmentID" value="@lineSegment.SegmentID" />
                <button type="submit" class="btn btn-danger" disabled="@(lineSegment is null)">Delete</button> |
                <a href="/linesegments">Back to List</a>
            </EditForm>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private LineSegment? lineSegment { get; set; }

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        lineSegment = await context.LineSegment.FirstOrDefaultAsync(m => m.SegmentID == Id);
    }

    public async Task DeleteSegment()
    {
        using var context = DbFactory.CreateDbContext();
        var toDelete = await context.LineSegment.FindAsync(Id);

        if (toDelete != null)
        {
            context.LineSegment.Remove(toDelete);
            await context.SaveChangesAsync();
        }
        NavigationManager.NavigateTo("/linesegments");
    }
}
@page "/operators/delete"
@using Microsoft.EntityFrameworkCore
@using RailwayWeb.Data
@inject IDbContextFactory<RailwayWebContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Operator</PageTitle>

<h1>Delete Operator</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Operator</h4>
    <hr />
    @if (operatorModel is null)
    {
            <p><em>Loading...</em></p>
    }
    else
    {
            <dl class="row">
                <dt class="col-sm-2">ID</dt>
                <dd class="col-sm-10">@operatorModel.OperatorID</dd>

                <dt class="col-sm-2">Name</dt>
                <dd class="col-sm-10">@operatorModel.Name</dd>

                <dt class="col-sm-2">Company ID</dt>
                <dd class="col-sm-10">@operatorModel.WorkingCompanyID</dd>
            </dl>

            <EditForm Method="Post" Model="operatorModel" OnValidSubmit="DeleteOperator" FormName="delete" Enhance>
                 <input type="hidden" name="operatorModel.OperatorID" value="@operatorModel.OperatorID" />
                <button type="submit" class="btn btn-danger">Delete</button> |
                <a href="/operators">Back to List</a>
            </EditForm>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private Operator? operatorModel { get; set; }

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        operatorModel = await context.Operator.FirstOrDefaultAsync(m => m.OperatorID == Id);
    }

    public async Task DeleteOperator()
    {
        using var context = DbFactory.CreateDbContext();
        var toDelete = await context.Operator.FindAsync(Id);

        if (toDelete != null)
        {
            context.Operator.Remove(toDelete);
            await context.SaveChangesAsync();
        }
        NavigationManager.NavigateTo("/operators");
    }
}
@page "/lines/delete"
@using Microsoft.EntityFrameworkCore
@using RailwayWeb.Data
@inject IDbContextFactory<RailwayWebContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Line</PageTitle>

<h1>Delete Line</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Line</h4>
    <hr />
    @if (line is null)
    {
            <p><em>Loading...</em></p>
    }
    else
    {
            <dl class="row">
                <dt class="col-sm-2">ID</dt>
                <dd class="col-sm-10">@line.LineID</dd>

                <dt class="col-sm-2">Company ID</dt>
                <dd class="col-sm-10">@line.OperatingCompanyID</dd>

                <dt class="col-sm-2">Start Station</dt>
                <dd class="col-sm-10">@line.StartFacilityID</dd>

                 <dt class="col-sm-2">End Station</dt>
                <dd class="col-sm-10">@line.EndFacilityID</dd>
            </dl>

            <EditForm Method="Post" Model="line" OnValidSubmit="DeleteLine" FormName="delete" Enhance>
            @*  *@
                <input type="hidden" name="line.LineID" value="@line.LineID" />
                <button type="submit" class="btn btn-danger" disabled="@(line is null)">Delete</button> |
                <a href="/lines">Back to List</a>
            </EditForm>
    }
</div>

@code {
    [SupplyParameterFromForm]
    private Line? line { get; set; }

    [SupplyParameterFromQuery]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        line = await context.Line.FirstOrDefaultAsync(m => m.LineID == Id);

        if (line is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    public async Task DeleteLine()
    {
        using var context = DbFactory.CreateDbContext();

       
        var lineToDelete = await context.Line.FindAsync(Id);

        if (lineToDelete != null)
        {
            context.Line.Remove(lineToDelete);
            await context.SaveChangesAsync();
        }
        NavigationManager.NavigateTo("/lines");
    }
}
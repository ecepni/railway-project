@page "/operatingcompanies/create"
@using Microsoft.EntityFrameworkCore
@using RailwayWeb.Data
@inject IDbContextFactory<RailwayWebContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Create Company</PageTitle>
<h1>Create New Company</h1>

<EditForm Model="OperatingCompany" OnValidSubmit="AddCompany" FormName="createCompany">
    <DataAnnotationsValidator />
    <div class="mb-3">
        <label>Company Name:</label>
        <InputText @bind-Value="OperatingCompany.Name" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
    <a href="/operatingcompanies" class="btn btn-secondary">Cancel</a>
</EditForm>

@code {
    [SupplyParameterFromForm] public OperatingCompany OperatingCompany { get; set; } = new();
    async Task AddCompany()
    {
        using var context = DbFactory.CreateDbContext();
        context.OperatingCompany.Add(OperatingCompany);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/operatingcompanies");
    }
}
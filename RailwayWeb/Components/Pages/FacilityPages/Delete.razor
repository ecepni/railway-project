@page "/facilities/delete"
@using Microsoft.EntityFrameworkCore
@using RailwayWeb.Data
@inject IDbContextFactory<RailwayWebContext> DbFactory
@inject NavigationManager NavigationManager

<PageTitle>Delete Facility</PageTitle>

<h1>Delete Facility</h1>

<h3>Are you sure you want to delete this?</h3>
<hr />

@if (facility is null)
{
        <p><em>Loading...</em></p>
}
else
{
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@facility.Name</dd>

            <dt class="col-sm-2">City</dt>
            <dd class="col-sm-10">@facility.City</dd>

            <dt class="col-sm-2">Capacity</dt>
            <dd class="col-sm-10">@facility.Capacity</dd>
        </dl>

    @*  *@
        <EditForm Method="Post" Model="facility" OnValidSubmit="ConfirmDelete" FormName="deleteFacilityForm" Enhance>
            <button type="submit" class="btn btn-danger">Yes, Delete It</button> |
            <a href="/facilities" class="btn btn-secondary">Back to List</a>
        </EditForm>
}

@code {
    [SupplyParameterFromQuery]
    public int Id { get; set; }

    [SupplyParameterFromForm]
    private Facility? facility { get; set; }

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();
        facility ??= await context.Facility.FirstOrDefaultAsync(m => m.FacilityID == Id);

        if (facility is null)
        {
            NavigationManager.NavigateTo("notfound");
        }
    }

    private async Task ConfirmDelete()
    {
        using var context = DbFactory.CreateDbContext();
        
        var toDelete = await context.Facility.FindAsync(Id);

        if (toDelete != null)
        {
            context.Facility.Remove(toDelete);
            await context.SaveChangesAsync();
        }

        NavigationManager.NavigateTo("/facilities");
    }
}